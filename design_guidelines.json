        }
      ]
    },
    "icons": {
      "library": "lucide-react",
      "style": "stroke-width: 1.5px"
    }
  },
  "implementation_guide": {
    "recommended_libraries": [
      {
        "name": "react-big-calendar",
        "purpose": "Task scheduling and calendar views",
        "install_cmd": "npm install react-big-calendar date-fns"
      },
      {
        "name": "recharts",
        "purpose": "Analytics and reporting charts",
        "install_cmd": "npm install recharts"
      },
      {
        "name": "react-map-gl",
        "purpose": "Map visualization (or leaflet/react-leaflet)",
        "install_cmd": "npm install react-map-gl mapbox-gl"
      }
    ],
    "universal_guidelines": [
      "Use 'Manrope' for all headings to ensure brand distinctiveness.",
      "Primary Action buttons must always be 'Blue-600' (#2563EB).",
      "Avoid gradients. Use solid colors and subtle borders.",
      "For Dashboards: Use the 'Bento' grid layout. Mix large summary cards with smaller metric cards.",
      "For Tables: Use zebra striping or hover-row effects for readability in data-heavy views.",
      "Map View: Ensure the map container takes up the remaining viewport height (calc(100vh - header_height)).",
      "All interactive elements must have a `data-testid` attribute.",
      "Do NOT use 'Inter' for headings. Use 'Manrope'.",
      "Input fields must have a distinct border color on focus.",
      "Use 'sonner' for all toast notifications."
    ]
  }
}