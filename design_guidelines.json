        },
        {
          "url": "https://images.unsplash.com/photo-1716749653173-d2e4865ad6de?auto=format&fit=crop&w=800&q=80",
          "alt": "Technician with camera/tool",
          "category": "people"
        },
        {
          "url": "https://images.unsplash.com/photo-1676378388741-61acfa5ac03b?auto=format&fit=crop&w=800&q=80",
          "alt": "Technician at laptop",
          "category": "people"
        }
      ],
      "inventory": [
        {
          "url": "https://images.unsplash.com/photo-1764114441097-6a475eca993d?auto=format&fit=crop&w=800&q=80",
          "alt": "Industrial lathe parts",
          "category": "equipment"
        },
        {
          "url": "https://images.unsplash.com/photo-1764114441005-df7e660bc2c8?auto=format&fit=crop&w=800&q=80",
          "alt": "Heavy machinery components",
