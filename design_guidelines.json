{
  "design_system": {
    "identity": {
      "name": "FieldOps Pro",
      "style_archetype": "Swiss Utility",
      "emotional_tone": "Precision, Reliability, Clarity",
      "core_values": ["Efficiency", "Visibility", "Control"]
    },
    "typography": {
      "font_family": {
        "primary": "Manrope, sans-serif",
        "secondary": "Inter, sans-serif",
        "mono": "JetBrains Mono, monospace"
      },
      "scale": {
        "h1": "text-4xl font-bold tracking-tight text-slate-900",
        "h2": "text-3xl font-semibold tracking-tight text-slate-900",
        "h3": "text-2xl font-semibold tracking-tight text-slate-900",
        "body_lg": "text-lg font-normal text-slate-700 leading-relaxed",
        "body": "text-base font-normal text-slate-600 leading-relaxed",
        "caption": "text-sm font-medium text-slate-500 uppercase tracking-wider",
        "label": "text-xs font-semibold text-slate-500 uppercase tracking-widest"
      },
      "imports": [
        "@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');"
      ]
    },
    "colors": {
      "primary": {
        "DEFAULT": "#2563EB",
        "foreground": "#FFFFFF",
        "hover": "#1D4ED8",
        "active": "#1E40AF"
      },
      "secondary": {
        "DEFAULT": "#0F172A",
        "foreground": "#F8FAFC"
      },
      "accent": {
        "DEFAULT": "#F1F5F9",
        "foreground": "#0F172A"
      },
      "background": {
        "DEFAULT": "#F8FAFC",
        "paper": "#FFFFFF",
        "sidebar": "#0F172A"
      },
      "status": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      },
      "border": {
        "DEFAULT": "#E2E8F0",
        "subtle": "#F1F5F9"
      }
    },
    "spacing": {
      "container_padding": "p-6 md:p-8 lg:p-12",
      "element_gap": "gap-4 md:gap-6",
      "section_gap": "gap-8 md:gap-12",
      "border_radius": {
        "sm": "rounded-sm",
        "md": "rounded-md",
        "lg": "rounded-lg",
        "full": "rounded-full"
      }
    },
    "visual_enhancers": {
      "shadows": {
        "card": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
        "hover": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "dropdown": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
      },
      "borders": {
        "default": "1px solid #E2E8F0",
        "active": "1px solid #2563EB",
        "dashed": "1px dashed #CBD5E1"
      },
      "glassmorphism": {
        "panel": "bg-white/90 backdrop-blur-md border border-white/20 shadow-lg"
      }
    },
    "layout_strategies": {
      "dashboard_grid": "grid grid-cols-1 md:grid-cols-12 gap-6",
      "card_grid": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6",
      "sidebar_layout": "flex h-screen overflow-hidden bg-slate-50",
      "bento_grid": "grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[minmax(180px,auto)]"
    },
    "component_styles": {
      "buttons": {
        "primary": "bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 rounded-md font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50",
        "secondary": "bg-secondary text-secondary-foreground hover:bg-secondary/80 h-10 px-4 py-2 rounded-md font-medium transition-colors",
        "outline": "border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2 rounded-md font-medium transition-colors",
        "ghost": "hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2 rounded-md font-medium transition-colors"
      },
      "cards": {
        "default": "rounded-lg border bg-card text-card-foreground shadow-sm p-6"
      },
      "inputs": {
        "default": "flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
      }
    }
  },
